ction\"]\nc:I[9241,[\"665\",\"static/chunks/f97e080b-43f5c70eecc65d7b.js\",\"84\",\"static/chunks/app/%5Blang%5D/layout-dc9606575a43356f.js\"],\"SiteHeader\"]\nd:I[4811,[\"665\",\"static/chunks/f97e080b-43f5c70eecc65d7b.js\",\"84\",\"static/chunks/app/%5Blang%5D/layout-dc9606575a43356f.js\"],\"ScrollReset\"]\ne:I[5613,[],\"\"]\n10:I[9046,[\"703\",\"static/chunks/app/%5Blang%5D/template-a9ce137537d05537.js\"],\"\"]\n11:I[1778,[],\"\"]\n12:I[8555,[\"665\",\"st"])</script><script>self.__next_f.push([1,"atic/chunks/f97e080b-43f5c70eecc65d7b.js\",\"84\",\"static/chunks/app/%5Blang%5D/layout-dc9606575a43356f.js\"],\"\"]\n14:I[8955,[],\"\"]\n7:T711,"])</script><script>self.__next_f.push([1,"\n## OMNI ART EXPO\n\n2021 年在疫情期间，很多留学生在美国无法完成线下毕业设计展。于是我联合国内校友，发起并组织了覆盖全美 10 所学校学生会的艺术高校联展。\n\n项目共收集了 1000 多份投稿，最终选择 200 余份作品，完成了一场面向公众开放的艺术高校联展。这个项目不仅是一次展览组织，也是在特殊时期为海外艺术与设计学生补上一场线下毕业展示的尝试。\n\n我和校友共同努力，最终将展览选址在上海百年建筑新泰仓库。开幕活动得到了上海市政府的支持与参观，也让这场由学生和校友发起的展览获得了更广泛的公共关注。\n\n\u003cdiv class=\"omni-gallery\"\u003e\n  \u003cfigure class=\"omni-gallery-main\"\u003e\n    \u003cimg src=\"/assets/images/omni-art-expo/image%2014.png\" alt=\"OMNI ART EXPO 开幕现场\" /\u003e\n    \u003cfigcaption\u003eOMNI ART EXPO 开幕现场\u003c/figcaption\u003e\n  \u003c/figure\u003e\n  \u003cdiv class=\"omni-gallery-row\"\u003e\n    \u003cfigure\u003e\n      \u003cimg src=\"/assets/images/omni-art-expo/image%2015.png\" alt=\"新泰仓库展览场地\" /\u003e\n      \u003cfigcaption\u003e新泰仓库展览场地\u003c/figcaption\u003e\n    \u003c/figure\u003e\n    \u003cfigure\u003e\n      \u003cimg src=\"/assets/images/omni-art-expo/image%2016.png\" alt=\"OMNI ART EXPO 展览入口与参展名单\" /\u003e\n      \u003cfigcaption\u003eOMNI ART EXPO 展览入口与参展名单\u003c/figcaption\u003e\n    \u003c/figure\u003e\n  \u003c/div\u003e\n  \u003cfigure class=\"omni-gallery-main\"\u003e\n    \u003cimg src=\"/assets/images/omni-art-expo/image%2017.png\" alt=\"OMNI ART EXPO 展览现场\" /\u003e\n    \u003cfigcaption\u003eOMNI ART EXPO 展览现场\u003c/figcaption\u003e\n  \u003c/figure\u003e\n\u003c/div\u003e\n\n\u003cvideo controls playsinline preload=\"metadata\" style=\"width:100%;border-radius:8px;margin:24px 0;\"\u003e\n  \u003csource src=\"/assets/images/omni-art-expo/exhibition-video.mp4\" type=\"video/mp4\" /\u003e\n  你的浏览器暂不支持视频播放。\n\u003c/video\u003e\n"])</script><script>self.__next_f.push([1,"f:[\"lang\",\"zh\",\"d\"]\n15:[]\n"])</script><script>self.__next_f.push([1,"1:[null,[\"$\",\"$L3\",null,{\"buildId\":\"9-NxvoqcdH-59x2hYrMq8\",\"assetPrefix\":\"\",\"initialCanonicalUrl\":\"/zh\",\"initialTree\":[\"\",{\"children\":[[\"lang\",\"zh\",\"d\"],{\"children\":[\"__PAGE__?{\\\"lang\\\":\\\"zh\\\"}\",{}]},\"$undefined\",\"$undefined\",true]}],\"initialSeedData\":[\"\",{\"children\":[[\"lang\",\"zh\",\"d\"],{\"children\":[\"__PAGE__\",{},[\"$L4\",[\"$\",\"main\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto px-5 max-w-[1024px]\",\"children\":[[\"$\",\"$L5\",null,{\"lang\":\"zh\"}],[\"$\",\"section\",null,{\"className\":\"mb-20\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-6 text-4xl md:text-5xl font-bold tracking-tighter leading-tight\",\"children\":\"经历\"}],[\"$\",\"$L6\",null,{\"experiences\":[{\"slug\":\"now\",\"title\":\"腾讯音乐娱乐公司\",\"date\":\"2026-05-15T11:03:46.566Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n我于 2024 年加入腾讯音乐娱乐集团 QQ 音乐设计团队，主要负责 AI 音乐创作、AI 唱、智能终端与创新音乐互动体验等方向的产品体验设计。入职后，我深度参与 QQ 音乐 AI 创作能力的产品化落地，围绕“降低音乐创作门槛，让普通用户也能参与创作”的目标，持续优化 AI 作歌、AI 唱、AI 改编、AIMV 等核心功能体验。\\n\\n在 AI 音乐创作方向，我参与并主导了一句话作歌、对话式作歌、哼唱成曲、图片作歌、音乐配方、AI 生成过程可视化等功能设计，重点优化用户输入成本、创作路径、等待体验与结果可控性，推动 AI 创作从“技术能力展示”转化为更易理解、更有参与感和传播性的音乐体验，并支持业务在用户活跃与收入层面的增长。\\n\\n同时，我也参与 QQ 音乐 TV、HarmonyOS、小米 Lite 等智能终端与跨设备项目，围绕不同设备场景下的听歌行为，设计播放器升级、锁屏歌词、状态栏歌词、音译歌词、疗愈模式、K 歌入口等体验，提升 QQ 音乐在多端生态中的一致性与场景化表达。\\n\\n2025 年起，我进一步探索 Vibe Coding、AI 原型工具与游戏化音乐互动，快速构建互动歌单扭蛋机、Mood Slot Machine、音乐跑酷、专辑封面消消乐、3D 拍立得播放器、360 度音乐空间等原型，将音乐体验从传统播放工具扩展为游戏、社交、情绪表达和个性化创作容器。\\n\\n总体而言，我在 QQ 音乐的工作聚焦于：将 AI 音乐创作与跨端音乐体验中的复杂技术能力，转化为用户可理解、可参与、可传播的产品体验，并持续探索 AI 时代设计师从“界面设计者”向“体验定义者与原型生产者”的角色转变。\\n\\n![腾讯音乐娱乐集团 QQ 音乐设计团队合影](/assets/images/tencent-music/team-photo.jpg)\\n\",\"preview\":false,\"intro\":\"负责 QQ 音乐 AI 音乐创作板块与 Vemus 未音，从产品定位到核心交互设计\",\"location\":\"深圳\",\"dateRange\":\"2024.09 - 至今\",\"type\":\"全职\",\"sorting\":7,\"area\":[\"*AI\",\"*产品设计\",\"用户研究\",\"多端设计\",\"设计提效\"],\"skill\":[],\"favicon\":\"/assets/favicon/tme.svg\",\"firstImage\":\"/assets/images/tencent-music/team-photo.jpg\"},{\"slug\":\"work\",\"title\":\"南加大世界建构媒体实验室\",\"date\":\"2026-05-15T11:03:46.566Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n我在南加大世界建构媒体实验室担任 VR 用户体验设计师，主导 World In A Cell VR 教育游戏的 VR 交互流程及用户界面设计。\\n\\n主要工作包括：\\n\\n- 通过创新性的交互设计和用户中心方法提升用户沉浸感与学习效率；\\n- 主导 30+ 次可用性测试和场景测试，输出分析报告并推动关键优化；\\n- 与南加州大学生物科学家合作开发 VR 交互式细胞生物学学习工具；\\n- 项目于 2023 年秋季学期引入南加州大学生物系教学课程，帮助学生理解复杂生物概念。\\n\",\"preview\":false,\"intro\":\"主导 World In A Cell VR 教育游戏的 VR 交互流程与用户界面\",\"location\":\"洛杉矶\",\"dateRange\":\"2023.02 - 2024.05\",\"type\":\"兼职\",\"sorting\":6,\"area\":[\"*VR\",\"*UX\",\"教育游戏\",\"可用性测试\",\"学术研究\"],\"skill\":[],\"favicon\":\"/assets/favicon/usc.svg\",\"firstImage\":\"\"},{\"slug\":\"dora\",\"title\":\"Dora\",\"date\":\"2026-05-15T11:03:46.565Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n在 DORA，我主导公司官网的交互流程与界面设计，并深度参与早期及中期产品阶段的用户调研。\\n\\n- 负责官网交互流程与界面设计，提升整体专业度和用户吸引力；\\n- 访谈并分析近 200 位行业用户，构建用户画像，为产品方向提供洞察；\\n- 独立组织并设计 A/B 测试方案，系统收集反馈并迭代设计；\\n- 推动关键流程转化率与用户满意度提升。\\n\",\"preview\":false,\"intro\":\"参与 AI 产品早期与中期阶段设计，负责官网与核心产品体验优化\",\"location\":\"远程\",\"dateRange\":\"2022.05 - 2022.10\",\"type\":\"兼职\",\"sorting\":5,\"area\":[\"*AI\",\"*官网设计\",\"用户研究\",\"A/B 测试\"],\"skill\":[],\"favicon\":\"\",\"firstImage\":\"\"},{\"slug\":\"education\",\"title\":\"南加州大学\",\"date\":\"2026-05-15T11:03:46.565Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n## University of Southern California\\n\\n交互媒体研究硕士，2022.08 - 2024.05。GPA 3.94，参与多个跨专业交互媒体研究与应用项目，并以荣誉毕业生身份毕业。\\n\\n导师为 Marientina Gotsis，南加州大学创意媒体与行为健康实验室主任。\\n\\n## ArtCenter College of Design\\n\\n交互设计本科，2019.01 - 2022.04。在校期间进入院长荣誉名单（GPA \u003e 3.8/4.0），长期荣获学院奖学金，并以荣誉毕业生身份毕业。\\n\",\"preview\":false,\"intro\":\"交互媒体研究硕士，参与跨专业交互媒体研究与应用项目\",\"location\":\"洛杉矶\",\"dateRange\":\"2022.08 - 2024.05\",\"type\":\"研究生\",\"sorting\":4,\"area\":[\"*游戏设计\",\"*ARVR\",\"学术研究\"],\"skill\":[],\"favicon\":\"/assets/favicon/usc.svg\",\"firstImage\":\"\"},{\"slug\":\"tsinghua-future-lab\",\"title\":\"清华大学未来实验室\",\"date\":\"2026-05-15T11:03:46.566Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n在清华大学未来实验室担任交互设计及研究实习生，协助设计界面原型、参与实验，并协助撰写学术论文。\\n\\n- 参与清华大学自动驾驶智慧汽车管理系统交互界面设计，支持校园内 7 个自动驾驶汽车测试与监管；\\n- 与阿里巴巴合作，参与线上虚拟商城的交互流程、界面及动效设计；\\n- 设计、组织并参与老年人智能产品使用深度调研；\\n- 参与睡眠活动中脑电波研究并合作产出交互艺术作品；\\n- 协助研究员撰写论文 3 篇，参与交通管理系统设计模型与方法论整理。\\n\",\"preview\":false,\"intro\":\"参与自动驾驶智慧汽车管理系统、虚拟商城与老年智能产品研究\",\"location\":\"北京\",\"dateRange\":\"2021.05 - 2022.01\",\"type\":\"实习\",\"sorting\":3,\"area\":[\"*交互设计\",\"实验研究\",\"严肃游戏\"],\"skill\":[],\"favicon\":\"/assets/favicon/THU.webp\",\"firstImage\":\"\"},{\"slug\":\"artcenter-college-of-design\",\"title\":\"艺术中心设计学院\",\"date\":\"2026-05-15T11:03:46.565Z\",\"coverImage\":\"/assets/cover-image/ArtCenter.webp\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"/assets/cover-image/ArtCenter.webp\"},\"content\":\"\\n我本科毕业于艺术中心设计学院（ArtCenter College of Design）交互设计专业。ArtCenter 的学习训练强调高密度项目实践、清晰表达、系统性的交互思考，以及把想法快速推进为可讨论、可验证的设计方案。\\n\\n在校期间，我进入院长荣誉名单（GPA \u003e 3.8/4.0），长期荣获学院奖学金，并以荣誉毕业生身份毕业。\\n\\n这段经历为我后来的 AI 产品设计、VR 用户体验、交互媒体研究和策展项目打下了基础：既能关注体验细节，也能把设计放回真实用户、产品目标和商业语境中判断。\\n\\n核心积累：\\n\\n- 交互设计方法与用户体验设计；\\n- 原型、界面与体验叙事；\\n- 高强度项目制训练与公开表达；\\n- 跨学科设计思维与未来体验探索。\\n\",\"preview\":false,\"intro\":\"交互设计本科，院长荣誉名单、长期奖学金与荣誉毕业\",\"location\":\"洛杉矶\",\"dateRange\":\"2019.01 - 2022.04\",\"type\":\"本科\",\"sorting\":2,\"area\":[\"*交互设计\",\"荣誉本科\"],\"skill\":[],\"favicon\":\"/assets/favicon/artcentericon.webp\",\"firstImage\":\"/assets/cover-image/ArtCenter.webp\"},{\"slug\":\"curation\",\"title\":\"策展\",\"date\":\"2026-05-15T11:03:46.565Z\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"$7\",\"preview\":false,\"intro\":\"发起与策划机器人、艺术、设计与高校作品相关展览\",\"location\":\"上海\",\"dateRange\":\"2021.03 - 2025.09\",\"type\":\"策展\",\"sorting\":1,\"area\":[\"*策展\",\"艺术高校\",\"展览组织\",\"跨校协作\"],\"skill\":[],\"favicon\":\"\",\"firstImage\":\"\"}],\"lang\":\"zh\",\"isEn\":false,\"icon\":[\"$\",\"svg\",null,{\"stroke\":\"currentColor\",\"fill\":\"currentColor\",\"strokeWidth\":\"0\",\"viewBox\":\"0 0 256 256\",\"className\":\"w-4 h-4\",\"style\":{\"color\":\"$undefined\",\"position\":\"relative\",\"top\":\"1px\"},\"children\":[\"$undefined\",[[\"$\",\"path\",\"0\",{\"d\":\"M100,100a12,12,0,0,1,12-12h32a12,12,0,0,1,0,24H112A12,12,0,0,1,100,100ZM236,68V196a20,20,0,0,1-20,20H40a20,20,0,0,1-20-20V68A20,20,0,0,1,40,48H76V40a28,28,0,0,1,28-28h48a28,28,0,0,1,28,28v8h36A20,20,0,0,1,236,68ZM100,48h56V40a4,4,0,0,0-4-4H104a4,4,0,0,0-4,4ZM44,72v35.23A180.06,180.06,0,0,0,128,128a180,180,0,0,0,84-20.78V72ZM212,192V133.94A204.27,204.27,0,0,1,128,152a204.21,204.21,0,0,1-84-18.06V192Z\",\"children\":[]}]]],\"height\":\"1em\",\"width\":\"1em\",\"xmlns\":\"http://www.w3.org/2000/svg\"}]}]]}],[\"$\",\"section\",null,{\"className\":\"mb-32\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-8 text-4xl md:text-5xl font-bold tracking-tighter leading-tight\",\"children\":\"项目\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-3 gap-4\",\"children\":[[\"$\",\"$L8\",\"portfolio-site\",{\"href\":\"/zh/project/portfolio-site\",\"className\":\"group block\",\"children\":[[\"$\",\"$L9\",null,{\"src\":\"/assets/images/AIMusic/optimized/QQ%20MUSIC.webp\",\"alt\":\"QQ 音乐 AI 创作\"}],[\"$\",\"div\",null,{\"className\":\"mt-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[\"\",[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold leading-snug group-hover:underline\",\"children\":\"QQ 音乐 AI 创作\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-neutral-500 line-clamp-2 mt-1\",\"children\":\"负责AI唱作功能产品定位，核心交互与持续迭代\"}]]}]]}],[\"$\",\"$L8\",\"dashboard-concept\",{\"href\":\"/zh/project/dashboard-concept\",\"className\":\"group block\",\"children\":[[\"$\",\"$L9\",null,{\"src\":\"/assets/personal/project-dashboard.svg\",\"alt\":\"Vemus未音独立APP\"}],[\"$\",\"div\",null,{\"className\":\"mt-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[\"\",[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold leading-snug group-hover:underline\",\"children\":\"Vemus未音独立APP\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-neutral-500 line-clamp-2 mt-1\",\"children\":\"从0到1搭建AI唱作独立APP，探索AI生成音乐的独家体验\"}]]}]]}],[\"$\",\"$L8\",\"notes-system\",{\"href\":\"/zh/project/notes-system\",\"className\":\"group block\",\"children\":[[\"$\",\"$L9\",null,{\"src\":\"/assets/personal/project-notebook.svg\",\"alt\":\"World In A Cell\"}],[\"$\",\"div\",null,{\"className\":\"mt-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[\"\",[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold leading-snug group-hover:underline\",\"children\":\"World In A Cell\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-neutral-500 line-clamp-2 mt-1\",\"children\":\"南加大 VR 细胞生物学教育游戏，主导 VR 交互流程与用户界面设计\"}]]}]]}],[\"$\",\"$L8\",\"neoncity\",{\"href\":\"/zh/project/neoncity\",\"className\":\"group block\",\"children\":[[\"$\",\"$L9\",null,{\"src\":\"/assets/personal/project-lab.svg\",\"alt\":\"NeonCity VR 游戏\"}],[\"$\",\"div\",null,{\"className\":\"mt-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[\"\",[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold leading-snug group-hover:underline\",\"children\":\"NeonCity VR 游戏\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-neutral-500 line-clamp-2 mt-1\",\"children\":\"南加州大学高阶游戏项目，担任 UI/UX 首席设计师\"}]]}]]}],[\"$\",\"$L8\",\"dora-website\",{\"href\":\"/zh/project/dora-website\",\"className\":\"group block\",\"children\":[[\"$\",\"$L9\",null,{\"src\":\"/assets/personal/project-dashboard.svg\",\"alt\":\"DORA 官网与产品体验\"}],[\"$\",\"div\",null,{\"className\":\"mt-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1.5\",\"children\":[\"\",[\"$\",\"h3\",null,{\"className\":\"text-base font-semibold leading-snug group-hover:underline\",\"children\":\"DORA 官网与产品体验\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-neutral-500 line-clamp-2 mt-1\",\"children\":\"主导 DORA 官网交互流程与界面设计，并参与早期 AI 产品调研\"}]]}]]}]]}]]}],[\"$\",\"$La\",null,{\"writings\":[{\"slug\":\"how-i-work\",\"title\":\"AI 协作式设计方法\",\"date\":\"2025-01-01\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n在 AI 产品设计工作中，我持续探索 Vibe Coding 与 AI Coding 等 AI 协作式设计工具，将 AI 生成能力应用于 H5 活动页面、音乐播放器皮肤、IP 玩法和游戏化播放器。\\n\\n这类方法的价值不只在于“更快产出”，更在于让设计师更早接触产品逻辑、交互状态与工程约束，从而把概念阶段的想法更快转化为可验证的体验。\\n\",\"preview\":false,\"intro\":\"\",\"location\":\"\",\"dateRange\":\"\",\"type\":\"方法\",\"sorting\":0,\"area\":[],\"skill\":[],\"favicon\":\"\",\"firstImage\":\"\"},{\"slug\":\"hello-world\",\"title\":\"IF: Inclusive Futures\",\"date\":\"2021-06-01\",\"coverImage\":\"\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"\"},\"content\":\"\\n《IF: Inclusive Futures / 包容性未来》侧重描绘未来设计蓝图，使用将未来预测与以人为本的设计相结合的新方法，探讨到 2030 年全球身份识别、购物和个人身份可能发生的根本变化。\\n\\n我作为合著者参与该出版项目，围绕未来身份、包容性设计与人本体验进行研究和内容共创。\\n\",\"preview\":false,\"intro\":\"\",\"location\":\"\",\"dateRange\":\"\",\"type\":\"出版\",\"sorting\":0,\"area\":[],\"skill\":[],\"favicon\":\"\",\"firstImage\":\"\"}],\"lang\":\"zh\",\"isEn\":false}],[\"$\",\"$Lb\",null,{\"creations\":[{\"slug\":\"visual-experiment\",\"title\":\"国际机器人与艺术设计双年展\",\"date\":\"2025-05-01\",\"coverImage\":\"/assets/personal/project-lab.svg\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"/assets/personal/project-lab.svg\"},\"content\":\"\\n亦庄政府支持项目，2025.05 - 2025.09。我担任策展人 \u0026 设计师，全面负责双年展的策展定位与主题方向。\\n\\n工作包括展览结构与内容策划、国内外艺术家/设计师/科技团队作品甄选、国际化交流平台搭建、展览执行流程统筹、场地规划、作品布展、展览动线与观众体验设计。\\n\",\"preview\":false,\"intro\":\"\",\"location\":\"\",\"dateRange\":\"\",\"type\":\"\",\"sorting\":0,\"area\":[],\"skill\":[\"Curator\",\"Robotics\",\"Art\"],\"favicon\":\"\",\"firstImage\":\"/assets/personal/project-lab.svg\"},{\"slug\":\"prototype\",\"title\":\"OMNI Art Expo 全球艺术高校作品联展\",\"date\":\"2021-03-01\",\"coverImage\":\"/assets/personal/project-dashboard.svg\",\"excerpt\":\"\",\"ogImage\":{\"url\":\"/assets/personal/project-dashboard.svg\"},\"content\":\"\\n上海政府支持项目，2021.03 - 2021.06。我发起并组织 11 所美国、英国高校学生举办艺术与设计领域作品联展，并邀请业内校友进行分享和点评。\\n\\n项目征集 500 余份作品，评选 100 余份参展作品；邀请 50+ 位业内校友、100 位在场学生交流，日均参观 500 人次。展览场地位于上海新泰仓库，项目面积约 6000 平方米。\\n\",\"preview\":false,\"intro\":\"\",\"location\":\"\",\"dateRange\":\"\",\"type\":\"\",\"sorting\":0,\"area\":[],\"skill\":[\"Curator\",\"Founder\",\"Exhibition\"],\"favicon\":\"\",\"firstImage\":\"/assets/personal/project-dashboard.svg\"}],\"lang\":\"zh\",\"isEn\":false}]]}]}],null]]},[null,[\"$\",\"html\",null,{\"lang\":\"zh\",\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"link\",null,{\"rel\":\"icon\",\"type\":\"image/svg+xml\",\"href\":\"/favicon/favicon.svg\"}],[\"$\",\"link\",null,{\"rel\":\"shortcut icon\",\"href\":\"/favicon/favicon.ico\"}],[\"$\",\"link\",null,{\"rel\":\"manifest\",\"href\":\"/favicon/site.webmanifest\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-TileColor\",\"content\":\"#000000\"}],[\"$\",\"meta\",null,{\"name\":\"msapplication-config\",\"content\":\"/favicon/browserconfig.xml\"}],[\"$\",\"meta\",null,{\"name\":\"theme-color\",\"content\":\"#000\"}],[\"$\",\"link\",null,{\"rel\":\"alternate\",\"type\":\"application/rss+xml\",\"href\":\"/feed.xml\"}]]}],[\"$\",\"body\",null,{\"className\":\"bg-white text-neutral-900\",\"children\":[[\"$\",\"$Lc\",null,{\"lang\":\"zh\"}],[\"$\",\"$Ld\",null,{}],[\"$\",\"$Le\",null,{\"parallelRouterKey\":\"children\",\"segment